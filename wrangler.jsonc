{
  "$schema": "node_modules/wrangler/config-schema.json",
  "main": ".open-next/worker.js",
  "name": "agent-jobs-dashboard",
  "compatibility_date": "2025-11-18",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS",
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "agent-jobs-dashboard"
    }
  ],
  "images": {
    "binding": "IMAGES"
  },
  "observability": {
    "enabled": true
  },
  "vars": {
    "OPENSERV_WORKSPACE_ID": "12972",
    "OPENSERV_TRIGGER_URL": "https://api.openserv.ai/webhooks/trigger/ee932cdefb0f4d6da761f9b74877a2ee"
  }
}
