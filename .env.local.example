# OpenServ Agent API key (for fetching task results)
OPENSERV_API_KEY=your_openserv_api_key_here

# OpenServ workspace ID
OPENSERV_WORKSPACE_ID=12972

# OpenServ webhook trigger URL
# Format: https://api.openserv.ai/webhooks/trigger/{TRIGGER_TOKEN}
OPENSERV_TRIGGER_URL=https://api.openserv.ai/webhooks/trigger/your_trigger_token_here
